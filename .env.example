# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://yydnaisrgwiuuiespagi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase settings>
SUPABASE_SERVICE_ROLE_KEY=<from supabase settings — server only, NEVER commit>

# Anthropic
ANTHROPIC_API_KEY=<anthropic console>
# Optional — override vision model for document extraction
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# WhatsApp Business API (Meta for Developers)
WHATSAPP_PHONE_NUMBER_ID=<meta for developers — phone number ID, not the phone itself>
WHATSAPP_ACCESS_TOKEN=<meta for developers — system user long-lived token>
WHATSAPP_APP_SECRET=<meta for developers — app settings > basic > app secret; used to verify X-Hub-Signature-256>
WHATSAPP_VERIFY_TOKEN=<pick any string for webhook verification; you echo this to Meta during webhook setup>
